{
  "manifest_version": 2,
  "name": "ScryfallShowTags",
  "version": "1.0.1",

  "description": "Makes scryfall show card tags",

  "icons": {
    "48": "icons/border-48.png"
  },

  "content_scripts": [
    {
      "matches": ["*://scryfall.com/card/*"],
      "js": ["showTags.js"]
    }
  ],

  "permissions": [
    "https://tagger.scryfall.com/card/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}